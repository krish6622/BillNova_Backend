# BillNova backend environment (copy to .env; .env is gitignored)

# App
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg2://billnova:billnova@db:5432/billnova

# Auth / JWT  (generate a strong secret per environment)
JWT_SECRET=change-me-in-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# Subscription / trial defaults
TRIAL_DAYS=14
TRIAL_BILL_QUOTA=50

# Locale
DEFAULT_TIMEZONE=Asia/Kolkata

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
