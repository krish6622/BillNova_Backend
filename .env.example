# BillNova backend environment (copy to .env; .env is gitignored)

# App
ENVIRONMENT=development
DEBUG=true

# Database (SQLAlchemy + psycopg2 driver)
#  - Local Postgres:  postgresql+psycopg2://billnova:billnova@db:5432/billnova
#  - Managed (Neon):  postgresql+psycopg2://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql+psycopg2://billnova:billnova@db:5432/billnova

# Auth / JWT  (generate a strong secret per environment)
JWT_SECRET=change-me-in-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# Subscription / trial defaults
TRIAL_DAYS=14
TRIAL_BILL_QUOTA=50

# Manual subscription activation (platform ops). Set to a strong secret to enable
# the POST /api/subscription/activate endpoint (sent via the X-Admin-Key header).
# Leave empty to disable activation entirely.
ADMIN_API_KEY=

# Locale
DEFAULT_TIMEZONE=Asia/Kolkata

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
